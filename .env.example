# Sessions / flash. Local dev: any string. Production: openssl rand -hex 32
# On Render using this repo’s render.yaml, SECRET_KEY is created via generateValue.
SECRET_KEY=dev-secret-change-me

# Site branding (optional overrides; defaults show Novel Prep on all pages).
# SITE_BRAND_NAME=Novel Prep Math Studio
# SITE_BRAND_SHORT=Novel Prep
# SITE_LOGIN_KICKER=Novel Prep · SAT Math Studio
# SITE_TEACHER_LABEL=Novel Prep
# SITE_SUPPORT_CONTACT=Novel Prep

DESMOS_API_KEY=

# Optional: SQLite path. Use an absolute path on a persistent volume when hosting
# (e.g. Render disk mount). If unset, uses sat.db beside the app.
# DB_PATH=/var/data/sat.db
